comment2.params=o1\ o2
comment2.target=void\ swap(java.lang.String[],\ java.lang.String[])
comment2.text=\r\n\ [Req\ 11]\ Intercambia\ la\ posici\u00F3n\ de\ dos\ objetos\ en\ la\ torre.\r\n\ Los\ objetos\ se\ identifican\ por\ tipo\ y\ n\u00FAmero.\r\n\r\n\ @param\ o1\ objeto\ 1\:\ {"cup","4"}\ o\ {"lid","4"}\r\n\ @param\ o2\ objeto\ 2\:\ {"cup","3"}\ o\ {"lid","3"}\r\n\r\n\ Comportamiento\ seg\u00FAn\ combinaci\u00F3n\:\r\n\ \ \ cup\ \ <->\ cup\ \ \u2192\ intercambia\ tazas\ (y\ sus\ tapas\ van\ con\ ellas)\r\n\ \ \ lid\ \ <->\ lid\ \ \u2192\ intercambia\ solo\ las\ tapas\ entre\ dos\ tazas\r\n\ \ \ cup\ \ <->\ lid\ \ \u2192\ mueve\ la\ tapa\ de\ o2\ a\ la\ taza\ de\ o1\ y\ viceversa\r\n\r\n\ Ej\:\ swap({"cup","4"},\ {"cup","2"})\ intercambia\ tazas\ 4\ y\ 2\r\n\ \ \ \ \ swap({"lid","4"},\ {"lid","3"})\ intercambia\ tapas\ de\ tazas\ 4\ y\ 3\r\n
